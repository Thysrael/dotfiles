{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "permission": {
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask"
    },
    "zsh": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask"
    }
  },
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-supermemory@latest"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    }
  }
}
