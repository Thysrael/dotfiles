{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "github-copilot/gemini-3-flash-preview",
  "permission": {
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask"
    },
    "zsh": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask"
    },
    "external_directory": "allow",
  },
  "plugin": [
    "@tarquinen/opencode-dcp",
    "opencode-pty",
    "@mohak34/opencode-notifier",
    "@slkiser/opencode-quota"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "ast_grep": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ]
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  },
  "agent": {
    "cheap": {
      "description": "Cheap helper for lightweight drafting, web summarization, term lookup, and initial codebase exploration",
      "mode": "subagent",
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt": "You are a low-cost helper for lightweight tasks only. Good tasks: drafting docs, rewriting text, explaining terms, summarizing web pages, extracting facts, and initial codebase exploration. Prefer concise outputs. Do not make architectural decisions. Do not perform risky or broad code changes. If the task needs deeper judgment, uncertain technical conclusions, or non-trivial implementation, say so briefly and hand it back.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "lsp": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "bash": "allow",
        "edit": {
          "*.md": "allow",
          "*.mdx": "allow",
          "*": "deny"
        },
        "external_directory": "deny",
        "task": "allow",
        "skill": "allow"
      }
    }
  },
  "lsp": true,
  "formatter": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 20000
  }
}
