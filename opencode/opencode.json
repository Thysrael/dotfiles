{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai-horizon/gpt-5.5",
  "small_model": "github-copilot/gemini-3-flash-preview",
  "provider": {
    "openai-horizon": {
      "npm": "@ai-sdk/openai",
      "name": "OpenAI (Horizon)",
      "options": {
        "baseURL": "https://api.horizon1123.top/v1",
        "apiKey": "{env:OPENAI_HORIZON_API_KEY}"
      },
      "models": {
        "gpt-5.2": {
          "name": "GPT-5.2",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.4": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1050000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 Mini",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.3-codex-spark": {
          "name": "GPT-5.3 Codex Spark",
          "limit": {
            "context": 128000,
            "output": 32000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "gpt-5.3-codex": {
          "name": "GPT-5.3 Codex",
          "limit": {
            "context": 400000,
            "output": 128000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {},
            "xhigh": {}
          }
        },
        "codex-mini-latest": {
          "name": "Codex Mini",
          "limit": {
            "context": 200000,
            "output": 100000
          },
          "options": {
            "store": false
          },
          "variants": {
            "low": {},
            "medium": {},
            "high": {}
          }
        }
      }
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask"
    },
    "zsh": {
      "*": "allow",
      "git add *": "deny",
      "git commit *": "deny",
      "git push *": "deny",
      "git reset *": "ask",
      "git stash *": "ask",
      "git checkout *": "ask",
      "git restore *": "ask",
      "git clean *": "ask",
      "git revert *": "ask",
      "git cherry-pick *": "ask",
      "git rebase *": "ask",
      "git merge *": "ask"
    },
    "external_directory": "allow"
  },
  "plugin": [
    "@tarquinen/opencode-dcp",
    "opencode-pty",
    "@mohak34/opencode-notifier"
    // "@slkiser/opencode-quota"
  ],
  "command": {
    "paper-review": {
      "description": "Review a systems paper with batched accept/skip/revise edits",
      "template": "Use the paper-review skill. Review by issue type across the paper, not by section. For each small batch, number findings, explain issues in Chinese, ask which numbers to accept, treat unlisted numbers as skipped unless custom instructions are given, and immediately apply accepted/custom edits before continuing. Keep edits minimal and evidence-backed. User arguments: $ARGUMENTS"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    },
    "gh_grep": {
      "type": "remote",
      "url": "https://mcp.grep.app"
    },
    "ast_grep": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/ast-grep/ast-grep-mcp",
        "ast-grep-server"
      ]
    },
    "exa": {
      "type": "remote",
      "url": "https://mcp.exa.ai/mcp",
      "enabled": true
    }
  },
  "agent": {
    "build": {
      "options": {
        "store": false
      }
    },
    "plan": {
      "options": {
        "store": false
      }
    },
    "ask": {
      "description": "Read-only primary agent for questions, explanations, and codebase investigation without write permissions",
      "mode": "primary",
      "model": "openai-horizon/gpt-5.4",
      "prompt": "You are a read-only Q&A agent. Use this agent for asking questions, explanations, codebase reading, documentation lookup, and codebase investigation. You may run only read-only inspection commands allowed by permissions. Do not edit files, create files, install dependencies, make commits, or perform side-effecting actions. If the user asks for changes, explain that this agent is read-only and suggest switching to a writing-capable agent.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "lsp": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "edit": "deny",
        "bash": "allow",
        "zsh": "allow",
        "external_directory": "allow",
        "task": "deny",
        "skill": "allow"
      }
    },
    "cheap": {
      "description": "Cheap helper for lightweight drafting, web summarization, term lookup, and initial codebase exploration",
      "mode": "subagent",
      "model": "github-copilot/gemini-3-flash-preview",
      "prompt": "You are a low-cost helper for lightweight tasks only. Good tasks: drafting docs, rewriting text, explaining terms, summarizing web pages, extracting facts, and initial codebase exploration. Prefer concise outputs. Do not make architectural decisions. Do not perform risky or broad code changes. If the task needs deeper judgment, uncertain technical conclusions, or non-trivial implementation, say so briefly and hand it back.",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "lsp": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "bash": "allow",
        "edit": "allow",
        "external_directory": "deny",
        "task": "allow",
        "skill": "allow"
      }
    }
  },
  "lsp": true,
  "formatter": false
}
