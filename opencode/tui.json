{
  "$schema": "https://opencode.ai/tui.json",
  "scroll_speed": 4,
  "scroll_acceleration": {
    "enabled": true
  },
  "keybinds": {
    "leader": "ctrl+x",
    "session_interrupt": "escape",
    "session_timeline": "<leader>g",
    "session_compact": "<leader>c",
    "display_thinking": "ctrl+o",
    "messages_half_page_up": "ctrl+u",
    "messages_half_page_down": "ctrl+d"
  }
}